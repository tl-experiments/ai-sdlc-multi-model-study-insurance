# Yotsuba Insurance Claims Processing Platform — Environment Configuration
# Copy this file to .env and fill in the values for your environment.

# ─── Node & Application ─────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ─── Database (PostgreSQL 16) ────────────────────────────────────
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://yotsuba_user:yotsuba_password@localhost:5432/yotsuba_claims_dev

# ─── JWT Authentication ─────────────────────────────────────────
# Secret key for signing JWTs. Use a strong random string in production.
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION_HOURS=24

# ─── Encryption (APPI PII Protection) ────────────────────────────
# Base64-encoded 32-byte key for AES-256-GCM encryption of special-care PII.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEK=your-base64-encoded-32-byte-key-change-this-in-production

# ─── Rate Limiting ──────────────────────────────────────────────
# Throttle configuration for /auth/login endpoint
THROTTLE_LOGIN_LIMIT=5
THROTTLE_LOGIN_WINDOW_MS=60000

# ─── Blob Storage (S3-compatible stub) ──────────────────────────
# For POC, evidence blobs are referenced by content-hash; actual storage is stubbed.
# In production, these would point to a real S3 or S3-compatible service.
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=yotsuba-claims-evidence
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# ─── Regulatory & Business Constants ────────────────────────────
# JFSA threshold (¥) — reserve changes crossing this trigger NotificationToRegulator
JFSA_RESERVE_THRESHOLD_YEN=100000000

# Reserve approval thresholds (¥)
RESERVE_APPROVAL_THRESHOLD_MANAGER_YEN=10000000
RESERVE_APPROVAL_THRESHOLD_DIRECTOR_YEN=10000000

# APPI consent version (incremented when consent terms change)
APPI_CONSENT_VERSION=1.0

# ─── Logging & Observability ────────────────────────────────────
# Pino logger configuration
LOG_FORMAT=json
LOG_PRETTY=false

# Request correlation tracking
REQUEST_ID_HEADER=x-request-id
CORRELATION_ID_HEADER=x-correlation-id

# ─── Testing (optional, used by jest.setup.cjs) ──────────────────
# If .env.test exists, it overrides these during test runs.
# Typically points to a separate test database.
TEST_DATABASE_URL=postgresql://yotsuba_test:yotsuba_test@localhost:5432/yotsuba_claims_test