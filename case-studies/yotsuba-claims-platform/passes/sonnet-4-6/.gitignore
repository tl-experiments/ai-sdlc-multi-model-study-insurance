# =============================================================================
# Yotsuba Insurance Holdings — Claims Processing Platform
# .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Node / npm
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn/
.pnp.*
package-lock.json.bak

# -----------------------------------------------------------------------------
# Environment / secrets — NEVER commit real credentials
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.test
.env.test.local
.env.production
.env.production.local
# .env.example is intentionally NOT ignored — it is committed as documentation

# -----------------------------------------------------------------------------
# Build output
# -----------------------------------------------------------------------------
dist/
build/
out/

# Vite / React workbench
web/dist/
web/build/

# NestJS compilation
*.js.map

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Prisma
# -----------------------------------------------------------------------------
# Generated client lives in node_modules; do not commit
prisma/generated/
# Prisma migration lock files that should not be committed in POC
# (comment out if you add proper migrations)
# prisma/migrations/

# -----------------------------------------------------------------------------
# Jest / test coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
jest-results.json
junit.xml
test-results/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
pino*.log

# -----------------------------------------------------------------------------
# OS / editor artefacts
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# JetBrains IDEs
.idea/
*.iml
*.iws

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# Vim / Emacs
*.swp
*.swo
*~
\#*\#

# -----------------------------------------------------------------------------
# Docker (Track B — not in scope for Track A but anticipated)
# -----------------------------------------------------------------------------
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tgz
*.tar.gz

# Temporary files
tmp/
temp/