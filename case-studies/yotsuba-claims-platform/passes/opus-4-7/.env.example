# ─────────────────────────────────────────────────────────────────────────
# Yotsuba Insurance Holdings · Claims Processing Platform
# Environment configuration template.
#
# Copy this file to `.env` and fill in environment-appropriate values.
# NEVER commit a populated `.env` to source control. The values below are
# safe, non-secret defaults suitable for local development only.
#
# Every variable here is read at process bootstrap (see `src/main.ts` and
# the per-module config consumers). Missing values for required variables
# will cause the app to fail fast at startup rather than degrade silently.
# ─────────────────────────────────────────────────────────────────────────

# ─── 1. Runtime profile ──────────────────────────────────────────────────
# One of: development | test | production
NODE_ENV=development

# HTTP listener for the NestJS API.
PORT=3000

# Public base URL the API advertises (used in Swagger server list and any
# self-referential links). No trailing slash.
API_BASE_URL=http://localhost:3000

# CORS allow-list for the Adjuster Workbench (Vite dev server defaults to
# 5173). Comma-separated; exact-match origins only — no wildcards in prod.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── 2. Database (PostgreSQL 16) ─────────────────────────────────────────
# Prisma reads DATABASE_URL exclusively. The schema is Postgres-only —
# Decimal(15,0) for yen amounts and Bytea for encrypted PII blobs depend
# on Postgres types and will not run on SQLite.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/yotsuba_claims?schema=public

# Optional: a separate URL used by the test runner. If unset, the Jest
# global setup falls back to `yotsuba_claims_test` on the same host.
# DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/yotsuba_claims_test?schema=public

# ─── 3. Authentication (JWT) ─────────────────────────────────────────────
# HMAC secret used to sign access tokens. MUST be a high-entropy random
# string in production (>= 32 bytes). Rotate by deploying a new value and
# invalidating outstanding tokens.
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-bytes-long

# Token lifetime. Accepts the `ms` / `jsonwebtoken` shorthand (e.g. 1h, 8h, 7d).
JWT_EXPIRES_IN=8h

# bcrypt cost factor for password hashing on the seed + login paths.
BCRYPT_ROUNDS=12

# ─── 4. Encryption — APPI special-care PII (Article 17) ──────────────────
# AES-256-GCM key-encryption-key. MUST be exactly 32 bytes when
# base64-decoded. Used to wrap per-record DEKs for these fields:
#   - reporter_phone_ct / reporter_email_ct
#   - insured_government_id_ct
#   - bank_account_for_payout_ct
#   - injury_details_ct
#   - witness_phone_ct
# Generate a production value with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# The default below decodes to 32 bytes of 0x00..0x1f — DEV/TEST ONLY.
ENCRYPTION_KEK_BASE64=AAECAwQFBgcICQoLDA0ODxAREhMUFRYXGBkaGxwdHh8=

# ─── 5. APPI compliance ──────────────────────────────────────────────────
# Consent version string stamped onto every FNOL intake. Bump this whenever
# the privacy notice text changes; the prior value remains valid for
# already-collected consents (immutability of audit trail).
APPI_CONSENT_VERSION=appi-2024-01

# ─── 6. Regulatory thresholds (JFSA / internal policy) ───────────────────
# Single reserve change >= this amount (in yen) emits a
# NotificationToRegulator row for the daily JFSA flush.
JFSA_RESERVE_THRESHOLD_YEN=100000000

# Reserve approval tiers (yen). Encoded here so policy changes are a
# config edit + a test update, not a code change.
#   <= RESERVE_MANAGER_THRESHOLD_YEN  → manager may approve alone
#   >  RESERVE_DIRECTOR_THRESHOLD_YEN → requires claims-director approval
RESERVE_MANAGER_THRESHOLD_YEN=1000000
RESERVE_DIRECTOR_THRESHOLD_YEN=10000000

# ─── 7. Logging (Pino) ───────────────────────────────────────────────────
# One of: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Pretty-print logs in development. Set to `false` in production so the
# log shipper sees structured JSON.
LOG_PRETTY=true

# ─── 8. Rate limiting (Throttler) ────────────────────────────────────────
# Brief mandates 5 req/min/IP on /auth/login. These knobs let ops tune
# without a redeploy.
RATE_LIMIT_LOGIN_TTL_SEC=60
RATE_LIMIT_LOGIN_MAX=5

# Global default throttler — generous; per-route overrides tighten this.
RATE_LIMIT_GLOBAL_TTL_SEC=60
RATE_LIMIT_GLOBAL_MAX=300

# ─── 9. Evidence blob storage (stubbed for Track A) ──────────────────────
# The brief stubs actual blob storage; only content-hash + blob_ref are
# persisted. These knobs document the eventual S3-compatible target so the
# stub's `blob_ref` shape is consistent.
EVIDENCE_BLOB_BUCKET=yotsuba-claims-evidence-dev
EVIDENCE_BLOB_PREFIX=s3://stub/

# ─── 10. Time zone ───────────────────────────────────────────────────────
# Domain logic deals in Japanese dates (loss_date windows, JFSA daily
# flush). Pin every process to Asia/Tokyo.
TZ=Asia/Tokyo

# ─── 11. Swagger / OpenAPI ───────────────────────────────────────────────
# Set to `false` to disable the /docs route in production if your edge
# proxy already exposes the spec elsewhere.
SWAGGER_ENABLED=true
SWAGGER_PATH=docs

# ─── 12. Correlation / request tracing ───────────────────────────────────
# Header name the correlation-id middleware honours on inbound requests.
# Anything matching is propagated into every AuditEvent for that request.
CORRELATION_ID_HEADER=x-correlation-id
REQUEST_ID_HEADER=x-request-id