# Phase 2 — secrets you set locally. NEVER commit a real .env file.
# Copy this to .env and fill in values.

# Anthropic API key (paid tier, billing enabled)
# Used by tools/run-pass.mjs for Opus / Sonnet / Haiku passes.
ANTHROPIC_API_KEY=

# Google Gemini API key (paid tier, billing enabled)
# Used by tools/run-pass.mjs for Gemini-routed phases in orchestrated passes.
GEMINI_API_KEY=

# GitHub fine-grained PAT scoped to tl-experiments/ai-sdlc-multi-model-study-insurance
# Used for `git push` from the local clone.
GITHUB_TOKEN=
